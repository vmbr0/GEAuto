# ===========================================
# GE Auto Import – Production / Development
# ===========================================
# Copy to .env and fill values. Never commit .env.

# -------------------------------------------------------------------
# Database (PostgreSQL – required, persistent)
# -------------------------------------------------------------------
# Development (local Docker):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ge_auto_import?schema=public"
# Production (VPS / Docker):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Docker Compose: set POSTGRES_PASSWORD below; DATABASE_URL is built from it.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ge_auto_import?schema=public"
POSTGRES_PASSWORD="postgres"

# -------------------------------------------------------------------
# NextAuth (required)
# -------------------------------------------------------------------
# Must be the public URL of the app (no trailing slash).
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# -------------------------------------------------------------------
# Email (Resend – optional; emails skipped if not set)
# -------------------------------------------------------------------
# Get key: https://resend.com
RESEND_API_KEY=""
# Sender address (must be verified in Resend)
EMAIL_FROM="GE Auto Import <noreply@yourdomain.com>"

# -------------------------------------------------------------------
# Optional
# -------------------------------------------------------------------
# LibreTranslate (optional)
# LIBRETRANSLATE_API_URL="https://libretranslate.com/translate"
# LIBRETRANSLATE_API_KEY=""
# Playwright (optional, dev)
# PLAYWRIGHT_BROWSER_PATH=""
